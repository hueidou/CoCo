# CoCo 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ============================================================================
# 基础配置
# ============================================================================

# 工作目录（存放数据库、日志、媒体文件等）
# COCO_WORKING_DIR=~/.coco

# 日志级别：debug, info, warning, error, critical
# COCO_LOG_LEVEL=info

# API 文档访问（开发环境开启）
# COCO_OPENAPI_DOCS=false

# ============================================================================
# 认证配置
# ============================================================================

# 启用认证系统
# COCO_AUTH_ENABLED=true

# JWT 令牌过期时间（秒）
# COCO_JWT_TOKEN_EXPIRY_SECONDS=604800  # 7天

# 会话过期时间（秒）
# COCO_SESSION_EXPIRY_SECONDS=86400  # 24小时

# 密码策略
# COCO_PASSWORD_MIN_LENGTH=8
# COCO_PASSWORD_REQUIRE_UPPERCASE=true
# COCO_PASSWORD_REQUIRE_LOWERCASE=true
# COCO_PASSWORD_REQUIRE_DIGITS=true
# COCO_PASSWORD_REQUIRE_SPECIAL=false

# 默认管理员用户
# COCO_DEFAULT_ADMIN_USERNAME=admin
# COCO_DEFAULT_ADMIN_EMAIL=

# 用户注册策略
# COCO_ALLOW_REGISTRATION=true
# COCO_REQUIRE_EMAIL_VERIFICATION=false

# 登录尝试限制
# COCO_LOGIN_ATTEMPT_LIMIT=5
# COCO_LOGIN_ATTEMPT_WINDOW_MINUTES=15

# ============================================================================
# OIDC / Keycloak 配置
# ============================================================================

# 启用 OIDC 认证
# COCO_OIDC_ENABLED=true

# 方法1：单 OIDC 提供商配置（使用以下变量）
# ----------------------------------------------------------
# Keycloak 客户端 ID
# COCO_OIDC_CLIENT_ID=coco

# Keycloak 客户端密钥（从 Keycloak 管理控制台获取）
# COCO_OIDC_CLIENT_SECRET=your-client-secret-here

# Keycloak Issuer URL
# COCO_OIDC_ISSUER_URL=https://coco.201609.xyz/auth/realms/coco

# 重定向 URI（CoCo 服务的回调地址）
# 注意：需要与 Keycloak 客户端配置中的重定向 URI 匹配
# COCO_OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback

# OIDC 作用域
# COCO_OIDC_SCOPES=openid profile email

# 方法2：多 OIDC 提供商配置（使用 JSON 数组）
# ----------------------------------------------------------
# COCO_OIDC_PROVIDERS='[
#   {
#     "id": "keycloak",
#     "name": "Keycloak (Coco)",
#     "enabled": true,
#     "client_id": "coco",
#     "client_secret": "your-client-secret-here",
#     "issuer_url": "https://coco.201609.xyz/auth/realms/coco",
#     "scopes": "openid profile email"
#   }
# ]'

# 方法2（多提供商）配置详解：
# [
#   {
#     "id": "keycloak",                    # 提供商唯一标识符
#     "name": "Keycloak (Coco)",           # 显示名称
#     "enabled": true,                     # 是否启用
#     "client_id": "coco",                 # 客户端 ID
#     "client_secret": "your-secret",      # 客户端密钥
#     "issuer_url": "https://...",         # Issuer URL
#     "scopes": "openid profile email",    # 作用域（可选，默认为 openid email profile）
#     "discovery_url": "https://.../.well-known/openid-configuration"  # 自动发现 URL（可选）
#   }
# ]

# ============================================================================
# CORS 配置（前端开发）
# ============================================================================

# CORS 允许的来源（逗号分隔）
# 示例：COCO_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
# COCO_CORS_ORIGINS=

# ============================================================================
# 数据库配置
# ============================================================================

# SQLite 数据库路径（自动创建）
# COCO_DATABASE_URL=sqlite:///~/.coco/coco_users.db

# ============================================================================
# LLM API 配置
# ============================================================================

# 最大重试次数
# COCO_LLM_MAX_RETRIES=3

# 退避策略基数
# COCO_LLM_BACKOFF_BASE=1.0

# 退避策略上限
# COCO_LLM_BACKOFF_CAP=10.0

# 最大并发请求数
# COCO_LLM_MAX_CONCURRENT=10

# 每分钟最大请求数（QPM）
# COCO_LLM_MAX_QPM=600

# 速率限制暂停时间（秒）
# COCO_LLM_RATE_LIMIT_PAUSE=5.0

# 速率限制抖动时间（秒）
# COCO_LLM_RATE_LIMIT_JITTER=1.0

# ============================================================================
# Docker 配置
# ============================================================================

# 容器内运行标志
# COCO_RUNNING_IN_CONTAINER=false

# ============================================================================
# 内存管理
# ============================================================================

# 内存压缩保留最近条目数
# COCO_MEMORY_COMPACT_KEEP_RECENT=3

# 内存压缩比率
# COCO_MEMORY_COMPACT_RATIO=0.7

# ============================================================================
# 工具保护
# ============================================================================

# 工具保护批准超时（秒）
# COCO_TOOL_GUARD_APPROVAL_TIMEOUT_SECONDS=600